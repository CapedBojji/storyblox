{
  "name": "ui-claps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A web story renderer for Roblox UI powered by Zune and DOM/CSS.",
  "bin": {
    "ui-claps": "./dist/node/cli.js"
  },
  "exports": {
    ".": "./dist/node/index.js"
  },
  "scripts": {
    "dev": "tsx src/node/cli.ts dev --config ui-claps.config.ts",
    "build": "node scripts/clean.mjs && tsc -p tsconfig.node.json && vite build && node scripts/copy-runtime.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "express": "^5.1.0",
    "fast-glob": "^3.3.3",
    "open": "^10.2.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
