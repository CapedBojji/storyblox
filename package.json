{
  "name": "storyblox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A web story renderer for Roblox UI powered by Zune and DOM/CSS.",
  "packageManager": "pnpm@11.8.0",
  "main": "./dist/vscode/extension.js",
  "engines": {
    "vscode": "^1.92.0"
  },
  "activationEvents": [
    "onCommand:uiClaps.openPreview"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "uiClaps.openPreview",
        "title": "UI Claps: Open Preview"
      }
    ],
    "configuration": {
      "title": "UI Claps",
      "properties": {
        "uiClaps.projectPath": {
          "type": "string",
          "default": "",
          "description": "Default project folder to use when opening a UI Claps preview."
        },
        "uiClaps.configPath": {
          "type": "string",
          "default": "",
          "description": "Default ui-claps config file to use when opening a UI Claps preview."
        }
      }
    }
  },
  "bin": {
    "storyblox": "./dist/node/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./roblox-ts": {
      "types": "./roblox-ts.d.ts"
    },
    "./rovy-vide": {
      "types": "./rovy-vide.d.ts",
      "default": "./rovy-vide.luau"
    },
    "./rovy": {
      "types": "./rovy.d.ts",
      "default": "./rovy.luau"
    }
  },
  "types": "./dist/node/index.d.ts",
  "scripts": {
    "dev": "tsx src/node/cli.ts dev --config ui-claps.config.ts",
    "build": "node scripts/clean.mjs && tsc -p tsconfig.node.json && vite build && node scripts/copy-runtime.mjs",
    "docs:dev": "vite --config vite.docs.config.ts",
    "docs:build": "vite build --config vite.docs.config.ts",
    "docs:preview": "vite preview --config vite.docs.config.ts",
    "package:release": "node scripts/package-release.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@fontsource/nunito-sans": "^5.2.7",
    "express": "^5.1.0",
    "fast-glob": "^3.3.3",
    "lucide-react": "^1.23.0",
    "open": "^10.2.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "1.92.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
